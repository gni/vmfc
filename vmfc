#!/bin/bash
set -euo pipefail
trap 'echo "⚠️ Command failed at line $LINENO" >&2; exit 1' ERR INT
[[ "${VMT_DEBUG:-0}" == "1" ]] && set -x

WORKDIR="${WORKDIR:-$HOME/fc-vms}"
WAN_IF="${WAN_IF:-wlan0}"
SHARED_NET_NAME="${SHARED_NET_NAME:-fcbr0}"
SHARED_NET_ADDR="${SHARED_NET_ADDR:-192.168.201.1}"
SHARED_NET_MASK="${SHARED_NET_MASK:-255.255.255.0}"
SHARED_NET_CIDR="${SHARED_NET_CIDR:-192.168.201.0/24}"
JAIL_UID="${JAIL_UID:-3000}"
JAIL_GID="${JAIL_GID:-3000}"
JAIL_BASE_DIR="${JAIL_BASE_DIR:-/srv/jailer/firecracker}"
DNS_SERVER="${DNS_SERVER:-1.1.1.1}"
VM_IFACE="${VM_IFACE:-eth0}"
VM_USER="${VM_USER:-devops}"
FC_GITHUB_API="https://api.github.com/repos/firecracker-microvm/firecracker/releases/latest"
BIN_DIR="/usr/local/bin"
PACMAN_PKGS="base linux openssh sudo systemd"
VIRTIO_MODULES="virtio_pci virtio_blk virtio_net virtio_mmio"
LINUX_EXTRACT_URL="https://raw.githubusercontent.com/torvalds/linux/master/scripts/extract-vmlinux"
LINUX_EXTRACT_BIN="/tmp/extract-vmlinux"
IMAGE_CACHE="$WORKDIR/.images"
SSH_KEY_DIR="$WORKDIR/.ssh"
SSH_KEY_PATH="$SSH_KEY_DIR/id_ed25519"
LOGS_FOLDER="$WORKDIR/.logs"
FC_VERSION_FILE="$WORKDIR/.fc_version"
LAST_CHECK_FILE="$WORKDIR/.last_update_check"

ACTION=${1:-}
RAW_NAME=${2:-}
RAM_MB=${3:-1024}
CPUS=${4:-2}
DISK_GB=${5:-5}
USAGE="usage: $0 {bootstrap|create|apply|destroy|delete|ssh|ls|stop|update} NAME [RAM_MB] [CPUS] [DISK_GB]"

if [[ -z "${ACTION}" ]]; then
  echo "$USAGE"
  exit 1
fi

NAME=""
case "$ACTION" in
  ls|bootstrap|update) ;;
  *)
    if [[ -z "${RAW_NAME}" ]]; then
      echo "$USAGE"
      exit 1
    fi
    NAME=$(echo "${RAW_NAME}" | tr -cd 'a-zA-Z0-9' | cut -c1-12)
    [[ -z "${NAME}" ]] && { echo "invalid NAME"; exit 1; }
    ;;
esac

VMPATH="$WORKDIR/$NAME"

init_dirs() {
  mkdir -p "$WORKDIR" "$IMAGE_CACHE" "$SSH_KEY_DIR" "$LOGS_FOLDER"
  chmod 700 "$SSH_KEY_DIR" "$WORKDIR" "$IMAGE_CACHE"
}

is_vm_running() {
  local vm_name="$1"
  local vm_dir="$WORKDIR/$vm_name"
  local pid_file="$vm_dir/fc.pid"

  if [[ -f "$pid_file" ]]; then
    local pid
    pid=$(cat "$pid_file")
    if sudo kill -0 "$pid" 2>/dev/null; then
      return 0
    else
      return 1
    fi
  fi
  return 1
}

fetch_firecracker() {
  local target_tag="${1:-}"
  
  if [[ -z "$target_tag" ]]; then
    echo "📦 Fetching latest Firecracker release metadata..."
    target_tag=$(curl -fsSL "$FC_GITHUB_API" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
  fi
  
  echo "📦 Downloading Firecracker $target_tag..."
  
  local arch_suffix
  if [[ "$(uname -m)" == "x86_64" ]]; then 
    arch_suffix="x86_64"
  elif [[ "$(uname -m)" == "aarch64" ]]; then 
    arch_suffix="aarch64"
  else 
    echo "❌ Unsupported architecture"
    exit 1
  fi

  local release_url="https://github.com/firecracker-microvm/firecracker/releases/download/${target_tag}/firecracker-${target_tag}-${arch_suffix}.tgz"
  curl -fsSL "$release_url" -o /tmp/firecracker.tgz
  tar -xzf /tmp/firecracker.tgz -C /tmp
  sudo mv "/tmp/release-${target_tag}-${arch_suffix}/firecracker-${target_tag}-${arch_suffix}" "$BIN_DIR/firecracker"
  sudo mv "/tmp/release-${target_tag}-${arch_suffix}/jailer-${target_tag}-${arch_suffix}" "$BIN_DIR/jailer"
  sudo chmod +x "$BIN_DIR/firecracker" "$BIN_DIR/jailer"
  rm -rf "/tmp/release-${target_tag}-${arch_suffix}" /tmp/firecracker.tgz
  
  echo "$target_tag" > "$FC_VERSION_FILE"
  echo "✅ Firecracker $target_tag installed to $BIN_DIR"
}

check_for_updates() {
  echo "🔍 Checking GitHub for updates..."
  local latest_tag
  latest_tag=$(curl -sSL "$FC_GITHUB_API" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
  
  local current_version="none"
  if [[ -f "$FC_VERSION_FILE" ]]; then
      current_version=$(cat "$FC_VERSION_FILE")
  fi

  if [[ "$latest_tag" == "$current_version" ]]; then
      echo "✅ Firecracker is up to date ($current_version)."
  else
      echo "🚀 Update available: $current_version -> $latest_tag"
      if [ -t 0 ]; then
          read -r -p "🔄 Do you want to install the update now? [y/N] " install_resp
          if [[ "$install_resp" =~ ^([yY][eE][sS]|[yY])$ ]]; then
              fetch_firecracker "$latest_tag"
          fi
      else
          echo "⚠️ Running non-interactively. Skipping installation."
      fi
  fi
}

daily_update_prompt() {
  local today
  today=$(date +%Y-%m-%d)
  local last_check="none"

  if [[ -f "$LAST_CHECK_FILE" ]]; then
      last_check=$(cat "$LAST_CHECK_FILE")
  fi

  if [[ "$today" != "$last_check" ]]; then
      if [ -t 0 ]; then
          read -r -p "🔄 Do you want to check for Firecracker updates today? [y/N] " response
          if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
              check_for_updates
          fi
      fi
      echo "$today" > "$LAST_CHECK_FILE"
  fi
}

ip_prefix_from_addr() { 
  echo "${1%.*}" 
}

vm_ip_for_name() {
  local name="$1"
  local prefix gateway_octet hash host_octet
  prefix="$(ip_prefix_from_addr "$SHARED_NET_ADDR")"
  gateway_octet="${SHARED_NET_ADDR##*.}"
  hash=0
  for ((i=0; i<${#name}; i++)); do
    printf -v ord '%d' "'${name:i:1}"
    hash=$(((hash + ord) % 200))
  done
  host_octet=$((10 + hash))
  if [[ "$host_octet" -eq "$gateway_octet" ]]; then
    host_octet=$(((host_octet + 1) % 254))
    [[ "$host_octet" -le 1 ]] && host_octet=10
  fi
  echo "${prefix}.${host_octet}"
}

vm_mac_for_ip() {
  local ip="$1"
  local last_octet="${ip##*.}"
  printf "AA:FC:00:00:00:%02X\n" "$last_octet"
}

check_vm_dir() {
  [[ -d "$VMPATH" ]] || { echo "❌ VM '$NAME' not found"; exit 1; }
}

ensure_shared_network() {
  if [[ "$(sysctl -n net.ipv4.ip_forward)" == "0" ]]; then
    sudo sysctl -w net.ipv4.ip_forward=1 >/dev/null
  fi

  if ! ip link show "$SHARED_NET_NAME" >/dev/null 2>&1; then
    sudo ip link add name "$SHARED_NET_NAME" type bridge
  fi

  sudo ip link set dev "$SHARED_NET_NAME" up
  
  # Flush old IPs to prevent stacking
  sudo ip addr flush dev "$SHARED_NET_NAME" 2>/dev/null || true
  sudo ip addr add "${SHARED_NET_ADDR}/24" dev "$SHARED_NET_NAME" 2>/dev/null || true
  
  # VPN-SAFE NAT: Apply Masquerade globally, not tied to a specific interface
  sudo iptables -t nat -A POSTROUTING -s "$SHARED_NET_CIDR" -j MASQUERADE 2>/dev/null || true

  if command -v ufw >/dev/null 2>&1 && sudo ufw status | grep -q "Status: active"; then
    # Allow host <-> VM communication
    sudo ufw allow in on "$SHARED_NET_NAME"
    sudo ufw allow out on "$SHARED_NET_NAME"

    # ISOLATION - Block VMs from scanning or accessing the local LAN
    sudo ufw route deny in on "$SHARED_NET_NAME" to 10.0.0.0/8
    sudo ufw route deny in on "$SHARED_NET_NAME" to 172.16.0.0/12
    sudo ufw route deny in on "$SHARED_NET_NAME" to 192.168.0.0/16

    # VPN-SAFE ROUTING: Allow VM -> Internet routing out of ANY active interface
    sudo ufw route allow in on "$SHARED_NET_NAME"
  fi
}

setup_ssh_key() {
  if [[ ! -f "$SSH_KEY_PATH" ]]; then
    echo "🔑 Generating new SSH keys..."
    ssh-keygen -t ed25519 -f "$SSH_KEY_PATH" -N ""
    chmod 600 "$SSH_KEY_PATH"
  fi
}

init_dirs

case "$ACTION" in
  bootstrap)
    echo "📦 Installing host dependencies..."
    sudo pacman -S --needed arch-install-scripts e2fsprogs iproute2 ufw curl bc
    fetch_firecracker
    setup_ssh_key
    ensure_shared_network
    echo "✅ Bootstrap complete!"
    ;;
    
  update)
    check_for_updates
    ;;

  create)
    [[ -d "$VMPATH" ]] && { echo "❌ VM exists: $VMPATH"; exit 1; }
    setup_ssh_key
    ensure_shared_network
    mkdir -p "$VMPATH"
    
    echo "📦 Building raw ${DISK_GB}GB Ext4 filesystem..."
    fallocate -l "${DISK_GB}G" "$VMPATH/rootfs.ext4"
    mkfs.ext4 -q -F "$VMPATH/rootfs.ext4" >/dev/null
    
    MNT_DIR="/tmp/fc-mnt-$NAME"
    sudo mkdir -p "$MNT_DIR"
    sudo mount -o loop "$VMPATH/rootfs.ext4" "$MNT_DIR"
    
    sudo mkdir -p "$MNT_DIR/etc"
    sudo touch "$MNT_DIR/etc/vconsole.conf"
    sudo bash -c "echo '/dev/vda / ext4 defaults 0 1' > $MNT_DIR/etc/fstab"
    
    echo "🐧 Running pacstrap..."
    sudo pacstrap -c "$MNT_DIR" $PACMAN_PKGS
    
    echo "🌍 Configuring system locale..."
    sudo sed -i 's/^#en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' "$MNT_DIR/etc/locale.gen"
    sudo arch-chroot "$MNT_DIR" locale-gen
    sudo bash -c "echo 'LANG=en_US.UTF-8' > $MNT_DIR/etc/locale.conf"
    
    echo "⚙️ Injecting VirtIO drivers..."
    sudo sed -i "s/^MODULES=()/MODULES=($VIRTIO_MODULES)/" "$MNT_DIR/etc/mkinitcpio.conf"
    sudo arch-chroot "$MNT_DIR" mkinitcpio -P
    
    echo "⚙️ Extracting Arch kernel..."
    if [[ ! -f "$LINUX_EXTRACT_BIN" ]]; then
        curl -fsSL "$LINUX_EXTRACT_URL" -o "$LINUX_EXTRACT_BIN"
        chmod +x "$LINUX_EXTRACT_BIN"
    fi
    sudo "$LINUX_EXTRACT_BIN" "$MNT_DIR/boot/vmlinuz-linux" > "$VMPATH/vmlinux.bin"
    sudo cp "$MNT_DIR/boot/initramfs-linux.img" "$VMPATH/initrd.img"
    
    echo "⚙️ Configuring systemd..."
    VM_IP=$(vm_ip_for_name "$NAME")
    sudo bash -c "echo '$NAME' > $MNT_DIR/etc/hostname"
    sudo bash -c "cat > $MNT_DIR/etc/systemd/network/20-wired.network" <<EOF
[Match]
Name=$VM_IFACE

[Network]
Address=${VM_IP}/24
Gateway=${SHARED_NET_ADDR}
DNS=${DNS_SERVER}
EOF

    echo "👤 Creating unprivileged user '$VM_USER' with sudo access..."
    sudo arch-chroot "$MNT_DIR" useradd -m -s /bin/bash "$VM_USER"
    sudo bash -c "echo '$VM_USER ALL=(ALL) NOPASSWD: ALL' > $MNT_DIR/etc/sudoers.d/$VM_USER"
    sudo chmod 0440 "$MNT_DIR/etc/sudoers.d/$VM_USER"
    
    echo "🔑 Configuring SSH access..."
    sudo mkdir -p "$MNT_DIR/root/.ssh" "$MNT_DIR/home/$VM_USER/.ssh"
    
    sudo bash -c "cat $SSH_KEY_PATH.pub > $MNT_DIR/root/.ssh/authorized_keys"
    sudo bash -c "cat $SSH_KEY_PATH.pub > $MNT_DIR/home/$VM_USER/.ssh/authorized_keys"
    
    sudo chmod 700 "$MNT_DIR/root/.ssh" "$MNT_DIR/home/$VM_USER/.ssh"
    sudo chmod 600 "$MNT_DIR/root/.ssh/authorized_keys" "$MNT_DIR/home/$VM_USER/.ssh/authorized_keys"
    
    sudo arch-chroot "$MNT_DIR" chown -R "$VM_USER:$VM_USER" "/home/$VM_USER/.ssh"
    
    sudo ln -sf /usr/lib/systemd/system/systemd-networkd.service "$MNT_DIR/etc/systemd/system/dbus-org.freedesktop.network1.service"
    sudo ln -sf /usr/lib/systemd/system/systemd-networkd.service "$MNT_DIR/etc/systemd/system/multi-user.target.wants/systemd-networkd.service"
    sudo ln -sf /usr/lib/systemd/system/systemd-resolved.service "$MNT_DIR/etc/systemd/system/multi-user.target.wants/systemd-resolved.service"
    sudo ln -sf /usr/lib/systemd/system/sshd.service "$MNT_DIR/etc/systemd/system/multi-user.target.wants/sshd.service"
    
    cd "$WORKDIR"
    sudo umount -l "$MNT_DIR"
    sleep 1
    sudo rm -rf "$MNT_DIR"
    
    VM_MAC=$(vm_mac_for_ip "$VM_IP")
    
    cat > "$VMPATH/config.json" <<EOF
{
  "boot-source": {
    "kernel_image_path": "vmlinux.bin",
    "initrd_path": "initrd.img",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off random.trust_cpu=on rw root=/dev/vda ip=${VM_IP}::${SHARED_NET_ADDR}:${SHARED_NET_MASK}:${NAME}:${VM_IFACE}:off"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "network-interfaces": [
    {
      "iface_id": "$VM_IFACE",
      "guest_mac": "${VM_MAC}",
      "host_dev_name": "fc-tap-${NAME}"
    }
  ],
  "machine-config": {
    "vcpu_count": ${CPUS},
    "mem_size_mib": ${RAM_MB},
    "smt": false
  }
}
EOF
    echo "✅ Arch microVM config created in $VMPATH"
    ;;
    
  apply|start)
    check_vm_dir
    
    if is_vm_running "$NAME"; then
      echo "✅ VM '$NAME' is already running (PID: $(cat "$VMPATH/fc.pid"))."
      exit 0
    fi
    
    daily_update_prompt
    
    TAP_DEV="fc-tap-$NAME"
    if ! ip link show "$TAP_DEV" >/dev/null 2>&1; then
      sudo ip tuntap add dev "$TAP_DEV" mode tap user "$JAIL_UID" group "$JAIL_GID"
      sudo ip link set dev "$TAP_DEV" master "$SHARED_NET_NAME"
      sudo ip link set dev "$TAP_DEV" up
    fi
    
    rm -f "$VMPATH/firecracker.sock"
    rm -f "$VMPATH/fc.pid"
    
    echo "🚀 Booting Arch Linux microVM (Jailed)..."
    
    FC_BIN=$(command -v firecracker || echo "$BIN_DIR/firecracker")
    JAIL_DIR="${JAIL_BASE_DIR}/$NAME/root"
    sudo mkdir -p "$JAIL_DIR"
    sudo ln -f "$VMPATH/rootfs.ext4" "$JAIL_DIR/"
    sudo ln -f "$VMPATH/vmlinux.bin" "$JAIL_DIR/"
    sudo ln -f "$VMPATH/initrd.img" "$JAIL_DIR/"
    sudo ln -f "$VMPATH/config.json" "$JAIL_DIR/"
    sudo chown "$JAIL_UID:$JAIL_GID" "$JAIL_DIR"/*
    
    sudo bash -c "nohup jailer --id \"$NAME\" --exec-file \"$FC_BIN\" --uid \"$JAIL_UID\" --gid \"$JAIL_GID\" -- --no-api --config-file config.json > \"$VMPATH/fc.log\" 2>&1 & echo \$! > \"$VMPATH/fc.pid\""
    
    sleep 2
    if is_vm_running "$NAME"; then
      echo "⚡ Firecracker started successfully (PID: $(cat "$VMPATH/fc.pid"))"
      echo "🔑 Connect via: $0 ssh $NAME"
    else
      echo "❌ Firecracker failed to start. Check logs at $VMPATH/fc.log"
      exit 1
    fi
    ;;
    
  stop|destroy)
    check_vm_dir
    echo "🛑 Stopping VM '$NAME'..."
    
    CLEANUP_PERFORMED=0
    
    if is_vm_running "$NAME"; then
      PID=$(cat "$VMPATH/fc.pid")
      echo "⏳ Sending SIGTERM to PID $PID..."
      sudo kill -15 "$PID" 2>/dev/null || true
      
      for i in {1..5}; do
        if ! sudo kill -0 "$PID" 2>/dev/null; then
          break
        fi
        sleep 1
      done
      
      if sudo kill -0 "$PID" 2>/dev/null; then
        echo "⚠️ VM did not stop gracefully. Forcing with SIGKILL..."
        sudo kill -9 "$PID" 2>/dev/null || true
      fi
      echo "✅ Process stopped."
      CLEANUP_PERFORMED=1
    else
      echo "ℹ️ VM '$NAME' is not running."
    fi
    
    rm -f "$VMPATH/fc.pid" 2>/dev/null || true
    rm -f "$VMPATH/firecracker.sock" 2>/dev/null || true
    
    TAP_DEV="fc-tap-$NAME"
    if ip link show "$TAP_DEV" >/dev/null 2>&1; then
      sudo ip link del "$TAP_DEV"
      CLEANUP_PERFORMED=1
    fi
    
    if [[ -d "${JAIL_BASE_DIR}/$NAME" ]]; then
      sudo rm -rf "${JAIL_BASE_DIR}/$NAME" 2>/dev/null || true
      CLEANUP_PERFORMED=1
    fi
    
    if [[ "$CLEANUP_PERFORMED" -eq 1 ]]; then
      echo "🧹 VM environment cleaned up."
    fi
    ;;
    
  delete)
    "$0" stop "$NAME" || true
    MNT_DIR="/tmp/fc-mnt-$NAME"
    if [ -d "$MNT_DIR" ]; then
        sudo umount -l "$MNT_DIR" 2>/dev/null || true
        sudo rm -rf "$MNT_DIR" 2>/dev/null || true
    fi
    [[ -d "$VMPATH" ]] && { sudo rm -rf "$VMPATH"; echo "🗑️ removed $VMPATH"; }
    ;;
    
  ssh)
    check_vm_dir
    if ! is_vm_running "$NAME"; then
      echo "❌ VM '$NAME' is not running."
      exit 1
    fi
    IP=$(vm_ip_for_name "$NAME")
    shift 2 || true
    exec ssh -i "$SSH_KEY_PATH" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null "${VM_USER}@$IP" "$@"
    ;;
    
  ls)
    echo "📂 $WORKDIR"
    printf "%-15s %-15s %-10s %-5s\n" "NAME" "IP ADDRESS" "STATUS" "PID"
    echo "---------------------------------------------------"
    for vm_dir in "$WORKDIR"/*; do
      [[ -d "$vm_dir" ]] || continue
      vm_name=$(basename "$vm_dir")
      pid="-"
      state="stopped"
      
      if is_vm_running "$vm_name"; then
        pid=$(cat "$vm_dir/fc.pid")
        state="running"
      elif [[ -f "$vm_dir/fc.pid" ]]; then
        state="crashed"
      fi
      
      ip=$(vm_ip_for_name "$vm_name")
      printf "%-15s %-15s %-10s %-5s\n" "$vm_name" "$ip" "$state" "$pid"
    done
    ;;
esac